{
  "name": "@involve/shared",
  "version": "0.0.0",
  "private": true,
  "description": "Shared TypeScript types for the Dynamics platform — single source of truth for Dynamics 365 entity interfaces.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist .turbo"
  },
  "devDependencies": {
    "@involve/config": "*",
    "typescript": "^5.4.0"
  }
}
