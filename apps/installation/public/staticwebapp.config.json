{
  "$schema": "https://json.schemastore.org/staticwebapp.config.json",
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/assets/*", "/manifest.json", "/*.{png,svg,ico,webmanifest}"]
  },
  "routes": [
    {
      "route": "/index.html",
      "headers": { "Cache-Control": "no-cache" }
    },
    {
      "route": "/manifest.json",
      "headers": { "Cache-Control": "no-cache" }
    }
  ],
  "mimeTypes": {
    ".webmanifest": "application/manifest+json"
  }
}
